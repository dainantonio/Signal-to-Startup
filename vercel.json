{
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!_next/static).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/agent/monitor",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/agent/watcher",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/agent/scout",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/agent/digest",
      "schedule": "0 9 * * *"
    }
  ]
}
